{
  "name": "open-session",
  "private": true,
  "type": "module",
  "description": "Privacy-focused browser replay metadata SDK and viewer for encrypted Open Session payloads.",
  "license": "MIT",
  "author": "Open Session contributors",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yoziyo/open-session.git"
  },
  "bugs": {
    "url": "https://github.com/yoziyo/open-session/issues"
  },
  "homepage": "https://github.com/yoziyo/open-session#readme",
  "packageManager": "pnpm@10.33.3",
  "engines": {
    "node": ">=22.14.0",
    "pnpm": ">=10"
  },
  "scripts": {
    "build": "pnpm -r build",
    "check": "biome check . && pnpm typecheck",
    "format": "biome format --write .",
    "lint": "biome check .",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "test:pack": "node scripts/pack-verify.mjs",
    "bench:payload": "node --expose-gc --experimental-strip-types scripts/bench-payload.mjs",
    "typecheck": "tsc -b packages/protocol packages/sdk apps/viewer apps/sample-next",
    "release:verify": "pnpm check && pnpm test && pnpm test:e2e && pnpm build && pnpm test:pack && pnpm bench:payload",
    "release": "pnpm release:verify && node scripts/publish-tarballs.mjs"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.13",
    "@changesets/cli": "^2.31.0",
    "@playwright/test": "^1.59.1",
    "@vitejs/plugin-react": "6.0.1",
    "jsdom": "29.1.0",
    "typescript": "6.0.3",
    "vite": "8.0.10",
    "vitest": "4.1.5"
  },
  "pnpm": {
    "overrides": {
      "postcss": "8.5.12"
    }
  }
}
